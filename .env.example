# =============================================================
# ESG Mefali — Variables d'environnement (exemple)
# Copier ce fichier en `.env` à la racine puis remplir les valeurs.
# Aucune valeur réelle ne doit être commitée.
# =============================================================

# ----- Base de données PostgreSQL (dockerisée) -----
DB_PASSWORD=                 # Mot de passe utilisateur Postgres (OBLIGATOIRE)
POSTGRES_PORT=5432           # Port exposé par Docker (optionnel, défaut 5432)
POSTGRES_HOST=localhost      # Hôte Postgres (optionnel, défaut localhost)
POSTGRES_DB=esg_mefali       # Nom de la base (optionnel, défaut esg_mefali)
POSTGRES_USER=esg            # Utilisateur Postgres (optionnel, défaut esg)

# ----- LLM via OpenRouter (compatible OpenAI SDK) -----
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=                 # Clé API OpenRouter (OBLIGATOIRE — sans appel en F01)
LLM_MODEL=minimax/minimax-m2.7

# ----- Identification de l'application -----
APP_URL=http://localhost:3000

# ----- Authentification (utilisée en F02) -----
JWT_SECRET=                  # Secret de signature JWT (OBLIGATOIRE)

# ----- Embeddings Voyage AI (utilisé en F18) -----
VOYAGE_API_KEY=              # Clé Voyage AI (OBLIGATOIRE — sans appel en F01)

# ----- Speech-to-Text Whisper via Replicate (utilisé en F22) -----
REPLICATE_API_TOKEN=         # Token Replicate (OBLIGATOIRE)
