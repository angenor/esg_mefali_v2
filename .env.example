# =============================================================
# ESG Mefali — Variables d'environnement (exemple)
# Copier ce fichier en `.env` à la racine puis remplir les valeurs.
# Aucune valeur réelle ne doit être commitée.
# =============================================================

# ----- Base de données PostgreSQL (dockerisée) -----
DB_PASSWORD=                 # Mot de passe utilisateur Postgres (OBLIGATOIRE)
POSTGRES_PORT=5432           # Port exposé par Docker (optionnel, défaut 5432)
POSTGRES_HOST=localhost      # Hôte Postgres (optionnel, défaut localhost)
POSTGRES_DB=esg_mefali       # Nom de la base (optionnel, défaut esg_mefali)
POSTGRES_USER=esg            # Utilisateur Postgres (optionnel, défaut esg)

# ----- LLM via OpenRouter (compatible OpenAI SDK) -----
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=                 # Clé API OpenRouter (OBLIGATOIRE — sans appel en F01)
LLM_MODEL=minimax/minimax-m2.7

# ----- Identification de l'application -----
APP_URL=http://localhost:3000

# ----- Authentification (F02) -----
JWT_SECRET=                  # Secret de signature JWT (OBLIGATOIRE)
CSRF_SECRET=                 # Secret pour génération de tokens CSRF (OBLIGATOIRE)
COOKIE_DOMAIN=localhost      # Domaine des cookies de session
COOKIE_SECURE=false          # true en prod (HTTPS uniquement)
APP_USER_PASSWORD=           # Mot de passe rôle SQL app_user (Postgres)
MIGRATOR_PASSWORD=           # Mot de passe rôle SQL migrator (Postgres)

# ----- Email (F02 reset password) -----
EMAIL_BACKEND=console        # console | smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RESET_PASSWORD_BASE_URL=http://localhost:3000/reset-password
PASSWORD_RESET_TTL_MINUTES=60

# ----- Embeddings Voyage AI (utilisé en F18) -----
VOYAGE_API_KEY=              # Clé Voyage AI (OBLIGATOIRE — sans appel en F01)

# ----- Speech-to-Text Whisper via Replicate (utilisé en F22) -----
REPLICATE_API_TOKEN=         # Token Replicate (OBLIGATOIRE)

# ----- Agent LangGraph (F53) -----
# LLM_AGENT_MODE=raw désactive l'agent et restaure le proxy LLM brut F13,
# sans rebuild ; ne nécessite que reload de l'env (instant rollback).
LLM_AGENT_MODE=langgraph     # langgraph (défaut) | raw
LLM_AGENT_MAX_TOOLS=10       # Nombre max de tools exposés au LLM (FR-015)
LLM_AGENT_MAX_RETRIES=2      # Retries Pydantic max avant fallback texte (FR-006)
LLM_AGENT_TIMEOUT_S=30.0     # Timeout LLM par tour, en secondes (Q3 clarif)
LLM_AGENT_TRACE=db           # off | db | db+stdout (FR-015)

# ----- Agent Context Builder (F54) -----
# Budget tokens pour le system prompt construit dynamiquement (NFR-002).
# Au-delà, la stratégie de troncature ordonnée (US4) s'applique.
LLM_AGENT_PROMPT_BUDGET_TOKENS=4000
# Encoding tiktoken utilisé pour count_tokens (cl100k_base par défaut).
LLM_TIKTOKEN_ENCODING=cl100k_base

# ----- Agent Tool Dispatch & SSE Bridge (F55) -----
# Backend du rate limiter : in-memory (dev single-worker) ou redis (prod).
LLM_AGENT_RATE_LIMIT_BACKEND=memory
# Budget tokens pour la sérialisation des résultats READ (FR-015 ; default top-N).
LLM_AGENT_READ_BUDGET_TOKENS=1500
# TTL applicatif d'une confirmation user pour les mutations destructives (US3).
LLM_AGENT_CONFIRMATION_TTL_SECONDS=180
# Header HTTP utilisé par les admins pour activer le mode dry_run (US6).
LLM_AGENT_DRY_RUN_HEADER=X-Agent-DryRun

# ----- Agent Memory & Long-term Recall (F57, FR-013) -----
# Top-K messages anciens retenus par cosine search (US1).
LLM_AGENT_MEMORY_TOP_K=3
# Seuil de similarité cosine en dessous duquel un message ancien est ignoré.
LLM_AGENT_MEMORY_THRESHOLD=0.7
# Nombre de messages chronologiques chargés systématiquement (court terme).
LLM_AGENT_MEMORY_RECENT_COUNT=15
# Seuil de messages à partir duquel la compaction async s'enclenche (US6).
LLM_AGENT_COMPACT_THRESHOLD=100
# Taille du chunk fixe compacté à chaque trigger.
LLM_AGENT_COMPACT_BATCH_SIZE=50
# Budget tokens max du résumé compaction généré par le LLM.
LLM_AGENT_COMPACT_MAX_TOKENS=500
# Budget tokens du summary stocké dans agent_entity_memory (US7).
LLM_AGENT_ENTITY_MEMORY_MAX_TOKENS=800
# Budget tokens (sérialisation ToolMessage) pour le résultat recall_history.
LLM_AGENT_RECALL_HISTORY_MAX_TOKENS=800
# Rétention applicative des lignes recall_log (job ops post-MVP).
LLM_AGENT_RECALL_LOG_RETENTION_DAYS=90
